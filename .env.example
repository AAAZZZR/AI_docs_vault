# ==============================================================
# DocVault — Dev Environment
# Copy this to .env and fill in your API key.
# Everything else works out of the box with docker compose up.
# ==============================================================

# ── Provider Switch ─────────────────────────────────────────
# Choose your LLM provider: "anthropic" | "google" | "openai"
LLM_PROVIDER=google
# Choose your embedding provider: "google" | "openai"
EMBEDDING_PROVIDER=google
# Must match the embedding provider (google=768, openai=1536)
EMBEDDING_DIMENSIONS=768

# ── API Keys ────────────────────────────────────────────────
# Only fill in the key for your active provider.
# Leave the others blank.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Everything below is pre-configured for docker compose.
# You normally don't need to change any of these.

# DATABASE_URL=postgresql+asyncpg://docvault:docvault_dev@postgres:5432/docvault
# DATABASE_URL_SYNC=postgresql+psycopg2://docvault:docvault_dev@postgres:5432/docvault
# REDIS_URL=redis://redis:6379/0
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET_NAME=docvault-dev
# S3_ENDPOINT_URL=http://minio:9000
# DEV_AUTH_BYPASS=true
